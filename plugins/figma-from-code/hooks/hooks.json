{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__claude_ai_Figma__use_figma|mcp__plugin_figma_figma__use_figma|mcp__figma__use_figma",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/hooks/figma-prereqs-gate.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}\"/hooks/figma-instances-gate.js"
          }
        ]
      }
    ]
  }
}
